/* components/bid-panel/bid-panel.wxss */

.bid-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bid-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.bid-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.bid-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 24rpx;
}

.bid-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 16rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.bid-hint {
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}

.bid-current {
  font-size: 26rpx;
  color: #666;
}

.bid-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
  justify-content: center;
}

.bid-option {
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  font-size: 28rpx;
  color: #666;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 90rpx;
  transition: all 0.2s;
}

.bid-option:active {
  transform: scale(0.95);
}

.bid-option-active {
  background: #3498db;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.4);
}

.bid-option-score {
  background: #fff3e0;
  border: 2rpx solid #ffb74d;
  color: #e65100;
}

.bid-option-score.bid-option-active {
  background: #ff9800;
  color: #fff;
  border-color: #ff9800;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.4);
}

.bid-score-text {
  font-size: 32rpx;
  font-weight: bold;
}

.bid-score-label {
  font-size: 20rpx;
}

.bid-actions {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: #ecf0f1;
  color: #7f8c8d;
}

.btn-confirm {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
}

.btn-confirm[disabled] {
  background: #bdc3c7;
  color: #95a5a6;
}

.bid-history {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.bid-history-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.bid-record {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.bid-record-name {
  font-size: 26rpx;
  color: #333;
}

.bid-record-score {
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}
