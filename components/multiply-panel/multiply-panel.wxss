/* components/multiply-panel/multiply-panel.wxss */

.multiply-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.multiply-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.multiply-content {
  position: relative;
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.multiply-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 20rpx;
}

.multiply-team {
  text-align: center;
  margin-bottom: 28rpx;
}

.team-label {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
}

.team-defense { background: #3498db; }
.team-attack { background: #e74c3c; }

.team-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.multiply-options {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}

.multiply-option {
  flex: 1;
  padding: 20rpx 8rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.multiply-option:active {
  transform: scale(0.95);
}

.option-active {
  border-color: #3498db;
  background: #e3f2fd;
  box-shadow: 0 2rpx 8rpx rgba(52, 152, 219, 0.3);
}

.option-dao.option-active { border-color: #ff9800; background: #fff3e0; }
.option-lei.option-active { border-color: #f44336; background: #ffebee; }
.option-wo.option-active { border-color: #9c27b0; background: #f3e5f5; }
.option-zhua.option-active { border-color: #e74c3c; background: #fce4ec; }

.option-name { font-size: 26rpx; color: #333; }
.option-icon { font-size: 36rpx; font-weight: bold; }
.option-dao .option-icon { color: #ff9800; }
.option-lei .option-icon { color: #f44336; }
.option-wo .option-icon { color: #9c27b0; }
.option-zhua .option-icon { color: #e74c3c; }

.option-desc { font-size: 20rpx; color: #999; }

.multiply-info {
  text-align: center;
  padding: 16rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #f57c00;
  font-weight: 500;
}

.btn-confirm {
  width: 100%;
  padding: 20rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-confirm::after { border: none; }
