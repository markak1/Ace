/* components/game-info/game-info.wxss */

.game-info-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(44, 62, 80, 0.9);
  border-radius: 0 0 16rpx 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.info-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-value {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.trump-display {
  color: #e74c3c;
}

.bid-display {
  color: #ffc107;
}

.info-action {
  margin-left: auto;
}

.info-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}
