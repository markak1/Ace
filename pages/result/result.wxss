/* pages/result/result.wxss */

.result-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628, #1a237e);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-card {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.result-header {
  padding: 48rpx 32rpx;
  text-align: center;
}

.header-win { background: linear-gradient(135deg, #1b5e20, #2e7d32); }
.header-lose { background: linear-gradient(135deg, #0d47a1, #1565c0); }
.header-guangtou { background: linear-gradient(135deg, #b71c1c, #e53935); }

.result-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}

.result-body {
  padding: 32rpx;
}

.score-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.score-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.score-label {
  font-size: 22rpx;
  color: #999;
}

.score-num {
  font-size: 48rpx;
  font-weight: 800;
}

.score-item.attack .score-num { color: #e74c3c; }
.score-item.defense .score-num { color: #3498db; }

.score-target {
  font-size: 20rpx;
  color: #bbb;
}

.score-vs {
  font-size: 24rpx;
  color: #ccc;
  font-weight: bold;
}

.detail-list {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child { border-bottom: none; }

.highlight-row {
  background: #fff8e1;
  margin: 8rpx -32rpx 0;
  padding: 20rpx 32rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.highlight { color: #f57c00; }
.lose-text { color: #e74c3c; font-size: 32rpx; font-weight: bold; }

.result-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.result-footer {
  padding: 24rpx 32rpx 32rpx;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn::after { border: none; }

.btn-share {
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  color: #fff;
}

.btn-back {
  background: #ecf0f1;
  color: #7f8c8d;
}
