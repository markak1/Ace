/* pages/lobby/lobby.wxss */

.lobby-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1628 0%, #1a237e 40%, #283593 100%);
  padding: 40rpx 32rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.bg-card {
  position: absolute;
  font-size: 120rpx;
  opacity: 0.06;
  color: #fff;
}

.bg-card-1 { top: 80rpx; left: -30rpx; transform: rotate(-15deg); }
.bg-card-2 { top: 200rpx; right: -20rpx; transform: rotate(20deg); }
.bg-card-3 { bottom: 300rpx; left: 40rpx; transform: rotate(-10deg); }
.bg-card-4 { bottom: 150rpx; right: 60rpx; transform: rotate(25deg); }

/* 标题 */
.header {
  text-align: center;
  margin-bottom: 48rpx;
  position: relative;
}

.title-area {
  margin-bottom: 20rpx;
}

.game-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #ffc107;
  text-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.3);
  letter-spacing: 8rpx;
}

.game-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.logo-cards {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.logo-card {
  width: 64rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #ffc107;
  font-weight: bold;
  backdrop-filter: blur(8rpx);
}

.logo-card-1 { transform: rotate(-8deg); }
.logo-card-2 { transform: rotate(4deg); }
.logo-card-3 { transform: rotate(-2deg); }

/* 玩家信息 */
.player-section {
  margin-bottom: 36rpx;
}

.player-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.player-info {
  flex: 1;
}

.player-name {
  display: block;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.player-id {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* 区块标题 */
.section-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* 模式选择 */
.mode-section {
  margin-bottom: 32rpx;
}

.mode-options {
  display: flex;
  gap: 16rpx;
}

.mode-card {
  flex: 1;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.mode-card:active {
  transform: scale(0.97);
}

.mode-active {
  border-color: #3498db;
  background: rgba(52, 152, 219, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(52, 152, 219, 0.2);
}

.mode-icon {
  font-size: 48rpx;
}

.mode-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.mode-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 难度选择 */
.difficulty-section {
  margin-bottom: 32rpx;
}

.difficulty-options {
  display: flex;
  gap: 16rpx;
}

.diff-option {
  flex: 1;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.diff-option:active { transform: scale(0.97); }

.diff-active {
  border-color: #27ae60;
  background: rgba(39, 174, 96, 0.15);
}

.diff-name {
  display: block;
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.diff-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* 设置 */
.settings-section {
  margin-bottom: 40rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.setting-row + .setting-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.setting-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.setting-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ctrl-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  font-size: 32rpx;
  color: #fff;
}

.ctrl-btn:active { background: rgba(255, 255, 255, 0.2); }

.ctrl-value {
  font-size: 28rpx;
  color: #ffc107;
  font-weight: 500;
  min-width: 60rpx;
  text-align: center;
}

/* 开始按钮 */
.action-section {
  margin-bottom: 32rpx;
}

.btn-start {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #ffc107, #ff9800);
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.3);
  letter-spacing: 4rpx;
}

.btn-start::after { border: none; }
.btn-start:active { transform: scale(0.98); box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.3); }

/* 底部链接 */
.footer-links {
  display: flex;
  justify-content: center;
  gap: 48rpx;
}

.footer-link {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 12rpx;
}

.footer-link:active { color: rgba(255, 255, 255, 0.8); }

/* 规则弹窗 */
.rules-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.7);
}

.rules-content {
  width: 90%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.rules-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.rules-scroll {
  flex: 1;
  max-height: 60vh;
}

.rules-text {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rules-section {
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-top: 8rpx;
}

.rules-text text:not(.rules-section) {
  font-size: 24rpx;
  color: #555;
  line-height: 1.6;
}

.btn-close {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #3498db;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn-close::after { border: none; }

/* 房间弹窗 */
.room-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.7);
}

.room-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.room-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  color: #333;
  margin-bottom: 32rpx;
}

.room-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
}

.room-input:focus { border-color: #3498db; }

.room-actions {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.btn::after { border: none; }

.btn-cancel { background: #ecf0f1; color: #7f8c8d; }
.btn-confirm { background: #3498db; color: #fff; }
